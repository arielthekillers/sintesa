<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Redirect external .php requests to extensionless urls
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
    RewriteRule ^ %1 [R=301,L]

    # Internally rewrite extensionless urls to .php
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*?)/?$ $1.php [L]
</IfModule>
